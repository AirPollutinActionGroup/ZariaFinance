# Zariya frontend — build-time configuration.
# All variables are read exclusively through src/lib/config/env.js.

# Base URL for the backend API (relative by default; nginx/Vite proxy /api).
VITE_API_BASE_URL=/api

# Axios request timeout in milliseconds.
VITE_API_TIMEOUT_MS=30000

# Dev-server proxy target for /api (docker: http://backend:5174).
VITE_PROXY_TARGET=http://localhost:5174

# Role granted to "review mode" sessions while backend login is pending.
# One of: CEO | FINANCE_OFFICER | FUNDRAISING_LEAD
VITE_REVIEW_MODE_ROLE=FINANCE_OFFICER

# Approval authority shown on the pending-approval screen.
VITE_APPROVAL_AUTHORITY_EMAIL=technology@a-pag.org
